# ---- Server ----
# Port the Express server listens on.
PORT=3002
# Node environment: development | production | test
NODE_ENV=development

# ---- Database ----
# MongoDB connection string (MongoDB Atlas or local, e.g. mongodb://localhost:27017/ecommerce)
DB_CON_STRING=

# ---- Auth ----
# Secret used to sign JWTs. Use a long, random value in production.
TOKEN_KEY=
# JWT lifetime (zeit/ms format, e.g. 10h, 7d)
TOKEN_EXPIRES_IN=10h

# ---- CORS ----
# "*" to allow all origins, or a comma-separated list of allowed origins.
CORS_ORIGIN=*

# ---- Uploads ----
# Directory (relative to project root) where uploaded images are stored.
UPLOAD_DIR=public/uploads
# Max upload size in bytes (default 15 MB).
MAX_UPLOAD_BYTES=15728640

# ---- Rate limiting ----
# Max requests per IP per 15 minute window.
RATE_LIMIT_MAX=1000

# ---- Password recovery ----
# OTP time-to-live in minutes.
PASSWORD_RESET_OTP_TTL_MINUTES=10
# Length of the numeric OTP code.
PASSWORD_RESET_OTP_LENGTH=6
# Max invalid OTP attempts before requiring a new code.
PASSWORD_RESET_MAX_ATTEMPTS=5
# Sender address for recovery emails (required in production).
PASSWORD_RESET_EMAIL_FROM=

# ---- SMTP (password recovery emails) ----
# Required in production for sending recovery OTP emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Set to "true" for TLS on port 465.
SMTP_SECURE=false
