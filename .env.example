# ---- Server ----
# Port the Express server listens on.
PORT=3000
# Node environment: development | production | test
NODE_ENV=development

# ---- Database ----
# MongoDB connection string (MongoDB Atlas or local, e.g. mongodb://localhost:27017/ecommerce)
DB_CON_STRING=

# ---- Auth ----
# Secret used to sign JWTs. Use a long, random value in production.
TOKEN_KEY=
# JWT lifetime (zeit/ms format, e.g. 10h, 7d)
TOKEN_EXPIRES_IN=10h

# ---- CORS ----
# "*" to allow all origins, or a comma-separated list of allowed origins.
CORS_ORIGIN=*

# ---- Uploads ----
# Directory (relative to project root) where uploaded images are stored.
UPLOAD_DIR=public/uploads
# Max upload size in bytes (default 15 MB).
MAX_UPLOAD_BYTES=15728640

# ---- Rate limiting ----
# Max requests per IP per 15 minute window.
RATE_LIMIT_MAX=1000
