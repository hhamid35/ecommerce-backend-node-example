# ---- Server ----
# Port the Express server listens on.
PORT=3002
# Node environment: development | production | test
NODE_ENV=development

# ---- Database ----
# MongoDB connection string (MongoDB Atlas or local, e.g. mongodb://localhost:27017/ecommerce)
DB_CON_STRING=

# ---- Auth ----
# Secret used to sign JWTs. Use a long, random value in production.
TOKEN_KEY=
# JWT lifetime (zeit/ms format, e.g. 10h, 7d)
TOKEN_EXPIRES_IN=10h

# ---- CORS ----
# "*" to allow all origins, or a comma-separated list of allowed origins.
CORS_ORIGIN=*

# ---- Uploads ----
# Directory (relative to project root) where uploaded images are stored.
UPLOAD_DIR=public/uploads
# Max upload size in bytes (default 15 MB).
MAX_UPLOAD_BYTES=15728640

# ---- Rate limiting ----
# Max requests per IP per 15 minute window.
RATE_LIMIT_MAX=1000

# ---- Password recovery ----
PASSWORD_RESET_ENABLED=true
PASSWORD_RESET_OTP_TTL_MINUTES=20
PASSWORD_RESET_REQUEST_LIMIT=5
PASSWORD_RESET_COMPLETE_LIMIT=10
PASSWORD_RESET_MAX_ATTEMPTS=5
PASSWORD_RESET_MIN_PASSWORD_LENGTH=8
PASSWORD_RESET_LOG_OTP=false

# SMTP (required in production when password recovery is enabled)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
PASSWORD_RESET_EMAIL_FROM=
